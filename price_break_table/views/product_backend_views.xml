<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="product_template_form_price_break_tab" model="ir.ui.view">
            <field name="name">product.template.form.price.break.tab</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_form_view"/>
            <field name="arch" type="xml">
                <notebook position="inside">
                    <page string="Prix et quantités" name="price_break_tab">

                        <!-- Tableau 1 : Paliers de prix dégressifs -->
                        <separator string="Paliers de prix dégressifs"/>
                        <div class="alert alert-info" role="alert">
                            Gérez ici les paliers de prix par liste de prix (client final, distributeur, installateur…).
                            Chaque ligne crée une règle dans la liste de prix correspondante.
                            Le prix de référence pour les calculs d'économie est le prix de vente du produit.
                        </div>

                        <field name="price_break_item_ids"
                               nolabel="1"
                               context="{
                                   'default_product_tmpl_id': id,
                                   'default_compute_price': 'fixed',
                                   'default_min_quantity': 1
                               }">
                            <list editable="bottom"
                                  default_order="pricelist_id, min_quantity"
                                  decoration-success="savings_percent > 0"
                                  decoration-muted="savings_percent == 0">

                                <field name="pricelist_id"
                                       required="1"
                                       options="{'no_create': True}"
                                       string="Liste de prix"/>

                                <field name="min_quantity" string="Qté min palier"/>

                                <field name="compute_price" string="Type de calcul"/>

                                <field name="fixed_price"
                                       string="Prix fixe (€)"
                                       optional="show"
                                       readonly="compute_price != 'fixed'"/>

                                <field name="percent_price"
                                       string="Remise (%)"
                                       optional="show"
                                       readonly="compute_price != 'percentage'"/>

                                <field name="price_computed"
                                       string="Prix résultant"
                                       readonly="1"
                                       widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>

                                <field name="savings_percent"
                                       string="Économie %"
                                       readonly="1"/>

                                <field name="date_start"
                                       string="Valable du"
                                       optional="hide"/>

                                <field name="date_end"
                                       string="Valable au"
                                       optional="hide"/>

                                <field name="currency_id" column_invisible="1"/>

                            </list>
                        </field>

                        <!-- Tableau 2 : Remises par catégorie de client -->
                        <separator string="Remises par catégorie de client"/>
                        <div class="alert alert-info" role="alert">
                            Définissez une remise en % par rapport à une liste de prix de base pour une liste cible
                            (ex : installateurs = tarif public - 15%). Cliquez sur "Générer les tarifs" pour créer
                            automatiquement les règles de prix dans chaque liste cible.
                        </div>

                        <field name="pricelist_discount_ids"
                               nolabel="1"
                               context="{'default_product_tmpl_id': id}">
                            <list editable="bottom"
                                  default_order="base_pricelist_id, target_pricelist_id">

                                <field name="base_pricelist_id"
                                       required="1"
                                       options="{'no_create': True}"
                                       string="Liste de base"/>

                                <field name="target_pricelist_id"
                                       required="1"
                                       options="{'no_create': True}"
                                       string="Liste cible"/>

                                <field name="discount_percent" string="Remise %"/>

                                <field name="tier_preview"
                                       string="Aperçu paliers résultants"
                                       readonly="1"/>

                            </list>
                        </field>

                        <div class="o_row mt-2">
                            <button name="action_generate_discount_tarifs"
                                    type="object"
                                    string="Générer les tarifs"
                                    class="btn btn-primary"
                                    icon="fa-cogs"
                                    confirm="Cela va créer ou mettre à jour les règles de prix dans les listes cibles. Continuer ?"/>
                        </div>

                        <!-- Tableau 3 : Quantités minimales d'achat -->
                        <separator string="Quantités minimales d'achat"/>
                        <div class="alert alert-info" role="alert">
                            Définissez la quantité minimale de produits que le client doit commander selon
                            sa liste de prix. La commande sera bloquée si la quantité est inférieure.
                            Une quantité de 0 signifie aucune restriction.
                        </div>

                        <div class="o_row mb-2">
                            <button name="action_sync_pricelist_min_qty"
                                    type="object"
                                    string="Synchroniser les listes de prix"
                                    class="btn btn-secondary"
                                    icon="fa-refresh"/>
                        </div>

                        <field name="min_purchase_qty_ids"
                               nolabel="1"
                               context="{'default_product_tmpl_id': id}">
                            <list editable="bottom"
                                  default_order="pricelist_id">

                                <field name="pricelist_id"
                                       required="1"
                                       options="{'no_create': True}"
                                       string="Liste de prix"/>

                                <field name="min_purchase_qty"
                                       string="Qté min d'achat"
                                       required="1"/>

                            </list>
                        </field>

                    </page>
                </notebook>
            </field>
        </record>

    </data>
</odoo>
