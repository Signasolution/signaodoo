<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_product_product_form_watermark" model="ir.ui.view">
        <field name="name">product.product.form.watermark</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Filigrane" name="watermark_group" invisible="not image_variant_1920">
                    <field name="x_watermark_applied" readonly="1"/>
                    <div class="d-flex gap-2">
                        <button name="action_apply_watermark" type="object"
                                string="Appliquer le filigrane" class="btn btn-secondary"
                                confirm="L'image de la variante va être réécrite avec le filigrane du site associé. Continuer ?"/>
                        <button name="action_restore_original_image" type="object"
                                string="Restaurer l'image d'origine" class="btn btn-secondary"
                                invisible="not x_watermark_applied"/>
                    </div>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
