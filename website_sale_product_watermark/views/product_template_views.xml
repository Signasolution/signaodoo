<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Onglet "Filigrane" sur la fiche produit.

        On hérite volontairement de product_template_only_form_view (la vue
        PRIMAIRE réservée à la fiche "Modèle de produit") et non de la vue de
        base product_template_form_view partagée avec la fiche variante :
        l'onglet n'apparaît ainsi que sur la fiche produit, sans jamais
        s'appliquer aux fiches variantes (product.product) où résident des
        personnalisations Odoo Studio sensibles. On ajoute une page nommée en
        fin de notebook, ce qui n'altère aucun index positionnel utilisé par
        d'éventuelles vues Studio.
    -->
    <record id="view_product_template_only_form_watermark" model="ir.ui.view">
        <field name="name">product.template.form.watermark</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Filigrane" name="watermark">
                    <div class="d-flex gap-2 mb-3">
                        <button name="action_apply_watermark" type="object"
                                string="Appliquer le filigrane" class="btn btn-primary"
                                confirm="L'image du produit va être réécrite avec le filigrane du site associé. Continuer ?"/>
                        <button name="action_restore_original_image" type="object"
                                string="Restaurer l'image d'origine" class="btn btn-secondary"
                                invisible="not x_watermark_applied"/>
                    </div>
                    <group>
                        <field name="x_watermark_applied" readonly="1"/>
                        <field name="x_watermark_original_image" widget="image" class="oe_avatar"
                               readonly="1" invisible="not x_watermark_original_image"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
