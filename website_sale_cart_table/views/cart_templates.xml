<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Transforme la liste des lignes du panier (website_sale.cart_lines) en un
        tableau HTML classique.

        Principe : aucun t-field/t-esc/t-out/t-call existant n'est dupliqué ni
        réécrit. Chaque bloc (image, nom+description, quantité, prix ligne,
        bouton supprimer) est physiquement déplacé (position="move") depuis la
        structure flex d'origine vers les nouvelles cellules <td>. Seule la
        colonne "Prix unitaire" est un ajout, et elle appelle une méthode
        publique déjà utilisée ailleurs dans le template d'origine
        (line._get_displayed_unit_price(), cf. le prix barré en cas de remise).

        Le conteneur <div id="cart_products"> d'origine est volontairement
        conservé tel quel (id, t-if, classes) : le template standard
        website_sale.suggested_products_list hérite aussi de
        website_sale.cart_lines et fait un xpath position="inside" sur
        //div[@id='cart_products'] pour y ajouter le bloc "Suggested
        accessories". Si on renommait/supprimait ce div, ce template casserait
        à l'installation (erreur de validation de vue). Seul le <div> de ligne
        (t-foreach) à l'intérieur est remplacé par le <table>.

        IMPORTANT sur position="move" : les marqueurs <xpath position="move"/>
        ne sont traités par le moteur d'héritage Odoo QUE s'ils sont des
        enfants directs du bloc position="inside"/"after"/"before"/"replace".
        On ne peut donc pas construire le <table>/<thead>/<tbody>/<tr>/<td> et
        y imbriquer les déplacements en une seule opération : chaque
        déplacement se fait dans un <xpath> séparé, appliqué séquentiellement.
    -->
    <template id="cart_lines_table" inherit_id="website_sale.cart_lines" name="Panier - Affichage tableau">

        <!-- Étape 1 : insère le squelette du tableau (thead + tbody avec
             cellules vides) juste après la ligne flex d'origine. À ce stade,
             la ligne d'origine n'est pas encore touchée : tout son contenu
             est encore disponible pour les déplacements des étapes suivantes. -->
        <xpath expr="//div[@id='cart_products']/div[contains(@t-attf-class, 'o_cart_product')]" position="after">
            <div class="o_cart_table_wrapper">
            <table id="o_cart_table" class="table o_cart_table align-middle mb-0">
                <thead>
                    <tr>
                        <th class="o_cart_table_img"><span class="visually-hidden">Image</span></th>
                        <th class="o_cart_table_desc">Produit</th>
                        <th class="o_cart_table_unitprice text-end">Prix unitaire</th>
                        <th class="o_cart_table_qty text-center">Quantité</th>
                        <th class="o_cart_table_total text-end">Total</th>
                        <th class="o_cart_table_remove"><span class="visually-hidden">Supprimer</span></th>
                    </tr>
                </thead>
                <tbody>
                    <tr t-foreach="website_sale_order.website_order_line"
                        t-as="line"
                        t-attf-class="o_cart_product #{line.linked_line_id and 'optional_product info'}"
                        t-attf-data-product-id="#{line.product_id and line.product_id.id}">
                        <t t-if="line.product_id">
                            <td class="o_cart_table_img"/>
                            <td class="o_cart_table_desc"/>
                            <td class="o_cart_table_unitprice text-end">
                                <!-- Prix unitaire recalculé dynamiquement : même méthode que celle
                                     utilisée par le prix barré du template d'origine, elle applique
                                     les règles de pricelist (paliers min_quantity) selon la quantité
                                     actuelle de la ligne. -->
                                <span t-out="line._get_displayed_unit_price()"
                                      t-options="{'widget': 'monetary', 'display_currency': website_sale_order.currency_id}"/>
                            </td>
                            <td class="o_cart_table_qty text-center"/>
                            <td class="o_cart_table_total text-end"/>
                            <td class="o_cart_table_remove"/>
                        </t>
                    </tr>
                </tbody>
            </table>
            </div>
        </xpath>

        <!-- Étape 2 : déplace le bloc image (inchangé : t-field sur
             product_id.image_128, gestion des lignes non vendables). -->
        <xpath expr="//table[@id='o_cart_table']//td[contains(@class, 'o_cart_table_img')]" position="inside">
            <xpath expr="//div[@id='cart_products']/div[contains(@t-attf-class, 'o_cart_product')]//div[@style='width: 64px']" position="move"/>
        </xpath>

        <!-- Étape 3 : déplace le conteneur du bouton supprimer AVANT l'étape 4,
             car il est actuellement un enfant du bloc nom/description
             (flex-grow-1) qui sera déplacé ensuite. On l'en extrait donc
             en premier pour qu'il atterrisse dans sa propre colonne. -->
        <xpath expr="//table[@id='o_cart_table']//td[contains(@class, 'o_cart_table_remove')]" position="inside">
            <xpath expr="//div[@id='cart_products']/div[contains(@t-attf-class, 'o_cart_product')]//div[@name='o_wsale_cart_line_button_container']" position="move"/>
        </xpath>

        <!-- Étape 4 : déplace le bloc nom + description_sale + (le cas
             échéant) lignes de combo. Le lien produit (cart_line_product_link)
             et l'appel à cart_line_description_following_lines restent
             intacts. -->
        <xpath expr="//table[@id='o_cart_table']//td[contains(@class, 'o_cart_table_desc')]" position="inside">
            <xpath expr="//div[@id='cart_products']/div[contains(@t-attf-class, 'o_cart_product')]//div[contains(@class, 'flex-grow-1')]" position="move"/>
        </xpath>

        <!-- Étape 5 : déplace les contrôles de quantité (+/-, input, message
             d'avertissement) sans aucune modification : le JS
             website_sale.js cible ces éléments par leurs classes
             (.js_quantity, .js_add_cart_json) et par data-line-id /
             data-product-id, pas par leur position dans le DOM. -->
        <xpath expr="//table[@id='o_cart_table']//td[contains(@class, 'o_cart_table_qty')]" position="inside">
            <xpath expr="//div[@id='cart_products']/div[contains(@t-attf-class, 'o_cart_product')]//div[@name='website_sale_cart_line_quantity']" position="move"/>
        </xpath>

        <!-- Étape 6 : déplace le prix total de la ligne (price_subtotal /
             price_total selon la config du site), y compris le prix barré en
             cas de remise et le prix à l'unité de base (base_unit_price). -->
        <xpath expr="//table[@id='o_cart_table']//td[contains(@class, 'o_cart_table_total')]" position="inside">
            <xpath expr="//div[@id='cart_products']/div[contains(@t-attf-class, 'o_cart_product')]//div[@name='website_sale_cart_line_price']" position="move"/>
        </xpath>

        <!-- Étape 7 : une fois tout son contenu récupéré, l'ancien conteneur
             flex de la ligne est désormais vide ; on le supprime. Le <div
             id="cart_products"> parent, lui, n'est jamais touché. -->
        <xpath expr="//div[@id='cart_products']/div[contains(@t-attf-class, 'o_cart_product')]" position="replace"/>

    </template>

</odoo>
